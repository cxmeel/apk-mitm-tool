{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build apk-mitm-tool (PyInstaller)",
            "type": "process",
            "command": "pyinstaller",
            "args": [
                "--noconsole",
                "--onefile",
                "--hidden-import",
                "tkinterdnd2",
                "--collect-all",
                "tkinterdnd2",
                "--add-data",
                "VERSION;.",
                "main.py",
                "--name",
                "apk-mitm-tool"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
